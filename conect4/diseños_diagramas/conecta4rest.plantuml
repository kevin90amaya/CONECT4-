@startuml conecta4rest

component cliente_web {

  package resources {
    class index <DOM> {}
    class Controller  {}
    class View  {}
    class models {}
    class Mensssages {}
  }


}

component servidor_spring {

  package controllers {
    class ControllerSettingsMenu{}
    class ControllerGame{}
  }
  package servis {
    class ServisSettingsMenuPlayesrs{}
    class ServisSettingsMenuBoard{}
    class ServisGame{}
  }
  package model {
  class Players {}
  class HumanPlayer {}
  class ComputerPlayer {}
