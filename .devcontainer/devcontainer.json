{
  "name": "Conect4 Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/java:3-21-trixie",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "none",
      "installMaven": "true",
      "installGradle": "false"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/devcontainers/features/desktop-lite:1": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-spring-boot-dashboard",
        "firsttris.vscode-jest-runner",
        "dbaeumer.vscode-eslint",
        "ms-playwright.playwright"
      ]
    }
  },
  "forwardPorts": [9323, 6080, 5901],
  "postCreateCommand": "cd conect4 && npm install && npx playwright install-deps",
  "remoteUser": "root"
}
