pipeline {
    agent any

    environment {
        APP_NAME = 'conect4'
    }

    stages {
        stage('1. Verificación Inicial') {
            steps {
                echo '=== ¡Hola Jenkins! Iniciando Pipeline Mínimo de Conect4 ==='
                sh 'node -v || true'
                sh 'java -version || true'
            }
        }
        stage('2. Estructura Backend') {
            steps {
                echo '=== Verificando directorio del Backend ==='
                dir('conect4') {
                    sh 'ls -la'
                }
            }
        }
        stage('3. Estructura Frontend') {
            steps {
                echo '=== Verificando archivos de Frontend ==='
                dir('conect4') {
                    sh 'echo "Simulación de comprobación Frontend..."'
                }
            }
        }
    }

    // Limpieza estricta de basura en el servidor
    post {
        always {
            echo '=== Limpiando el Workspace para no dejar basura en el servidor ==='
            cleanWs()
        }
        success {
            echo '✅ Pipeline Mínimo completado con éxito.'
        }
        failure {
            echo '❌ Error en la ejecución del Pipeline.'
        }
    }
}
